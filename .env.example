# Optional overrides for docker-compose bind mounts
# Keep this file as reference; do not store real secrets here.

FIREFLY_MERGE_DATA_DIR=./data
FIREFLY_MERGE_CONFIG_DIR=../firefly-merge-config

# Enable HTTP Basic Auth by setting a password (leave username blank in the browser prompt).
# APP_SECRET=change-me-to-a-strong-random-secret

# Maximum upload size in bytes (default: 200 MB = 209715200).
# MAX_UPLOAD_BYTES=209715200
